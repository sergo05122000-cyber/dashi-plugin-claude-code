# /etc/dashi-plugin/webhook.env — example EnvironmentFile for
# dashi-plugin-webhook.service. Mode 0640, owner root:<service-user>.
#
# Copy → edit → install:
#   sudo install -m 0640 -o root -g <service-user> webhook.env /etc/dashi-plugin/webhook.env

# --- Listener bind. Default is loopback. Override to 0.0.0.0 ONLY behind a
#     TLS reverse proxy with IP allowlisting. ---
# WEBHOOK_BIND_HOST=127.0.0.1
# WEBHOOK_PORT=8094

# --- Auth: file containing the shared Bearer token (one line, no newline). ---
WEBHOOK_BEARER_FILE=/etc/dashi-plugin/webhook.token

# --- Agent identity + workspace (both required) ---
WEBHOOK_AGENT_NAME=<your-agent-name>
WEBHOOK_AGENT_WORKSPACE=/home/<service-user>/.claude-lab/<agent>/.claude

# --- Claude Code binary + spawn limits ---
CLAUDE_BIN=/usr/local/bin/claude
INVOCATION_TIMEOUT_SEC=1800
WEBHOOK_LOG_DIR=/var/log/dashi-plugin-webhook

# --- gbrain swarm enrichment fallback (v6.3) — optional ---
# Set WEBHOOK_GBRAIN_SWARM_URL to YOUR OWN gbrain MCP endpoint. The repo
# ships no default — stand up your own coordinator and expose it via
# Cloudflare Tunnel or a tailnet (see webhook-listener/README.md
# «Bring-your-own swarm endpoint»). Leave the var unset to disable
# enrichment entirely; the listener will then ack degraded payloads
# silently rather than pulling fresh state from gbrain.
# WEBHOOK_GBRAIN_SWARM_URL=https://mcp.<your-domain>/swarm/mcp
# WEBHOOK_GBRAIN_TOKEN_FILE=/home/<service-user>/.secrets/dashi-gbrain.token

# --- Telegram pre-ack to the owner (optional) ---
# Leave WEBHOOK_OWNER_CHAT_ID empty to disable owner pings entirely.
# WEBHOOK_OWNER_CHAT_ID=
# WEBHOOK_TG_BOT_TOKEN_FILE=/home/<service-user>/.secrets/telegram-bot-token
# WEBHOOK_NOTIFY_TTL_SEC=300
