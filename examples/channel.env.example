# dashi-plugin-claude-code · channel.env
#
# Скопируйте этот файл в /etc/dashi-plugin/<agent>/channel.env
# и заполните своими значениями.
#
# chmod 640 + chown root:<service-user>
#
# НЕ коммитьте реальные значения в git.

# ─── Telegram Bot API ────────────────────────────────────────────
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456789:AAH-replace-with-your-real-token

# Anti-spoof: числовая часть до ":" в TELEGRAM_BOT_TOKEN
TELEGRAM_EXPECTED_BOT_ID=123456789

# ─── Allowlist (кто может писать боту) ───────────────────────────
# Узнайте свой user_id у @userinfobot в Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789

# Group chat ID начинается с -100, узнать через @userinfobot или forward → @rawdatabot
# Если бот только для личных DM — оставьте такое же значение что и USER_IDS
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ─── Workspace ───────────────────────────────────────────────────
# Корень workspace агента — где лежит CLAUDE.md, core/, .mcp.json
TELEGRAM_WORKSPACE_ROOT=/home/agentctl/.claude-lab/myagent/.claude

# AGENT_ID используется для маршрутизации в multi-agent setup и в логах
AGENT_ID=myagent

# ─── State directory ─────────────────────────────────────────────
# Куда плагин пишет bot.pid, config.json, inbox (downloaded media), logs
# Изолируйте на каждого агента (shared/state/<agent>/telegram/)
TELEGRAM_STATE_DIR=/home/agentctl/.claude-lab/shared/state/myagent/telegram

# ─── Webhook (internal — для Claude hooks) ───────────────────────
# Bun слушает этот порт локально для PreToolUse/PostToolUse/Stop hooks
# Это НЕ Telegram webhook — это для Claude Code hooks integration
# Если есть несколько агентов на одной машине — портов должно быть разное
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8089

# ─── Memory hooks (опционально) ──────────────────────────────────
# Включает запись turn'ов в <workspace>/core/hot/recent.md
# и <workspace_parent>/logs/verbose-YYYY-MM-DD.jsonl
TELEGRAM_MEMORY_ENABLED=true
TELEGRAM_MEMORY_WORKSPACE=/home/agentctl/.claude-lab/myagent/.claude
TELEGRAM_MEMORY_AGENT_LABEL=MyAgent
TELEGRAM_MEMORY_SOURCE_TAG=tg
